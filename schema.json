{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/studio-prime/public-progress/schema.json",
  "title": "Studio Prime Public Client Progress",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "lang",
    "status",
    "taskPrefix",
    "summary",
    "updatedAt",
    "projects",
    "milestones",
    "sections"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "lang": {
      "type": "string",
      "enum": ["en", "es"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "idle", "paused"]
    },
    "taskPrefix": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "summary": {
      "type": "string"
    },
    "updatedAt": {
      "$ref": "#/$defs/date"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      },
      "minItems": 1
    },
    "milestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      },
      "minItems": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "items"],
      "properties": {
        "key": {
          "type": "string",
          "enum": ["backlog", "next", "needs_client", "in_review", "done"]
        },
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "reference",
        "projects",
        "milestone",
        "app",
        "title",
        "status",
        "createdAt",
        "doneAt",
        "summary",
        "nextStep",
        "checklist"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "number": {
          "type": "integer",
          "minimum": 0
        },
        "reference": {
          "type": "string",
          "pattern": "^[A-Z]{3}-\\d+$"
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project"
          },
          "minItems": 1
        },
        "milestone": {
          "$ref": "#/$defs/milestoneReference"
        },
        "app": {
          "$ref": "#/$defs/app"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["request", "bug", "question"]
        },
        "status": {
          "type": "string",
          "enum": ["backlog", "next", "needs_client", "in_review", "done"]
        },
        "createdAt": {
          "$ref": "#/$defs/date"
        },
        "doneAt": {
          "anyOf": [
            {
              "$ref": "#/$defs/date"
            },
            {
              "type": "null"
            }
          ]
        },
        "summary": {
          "type": "string"
        },
        "nextStep": {
          "type": "string"
        },
        "checklist": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checklistItem"
          },
          "minItems": 1
        },
        "clientContext": {
          "$ref": "#/$defs/clientContext"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachment"
          }
        }
      }
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "done"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "done": {
          "type": "boolean"
        }
      }
    },
    "clientContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "body"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "url"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["pdf", "image", "doc", "sheet", "link"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "emoji"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "emoji": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "milestoneReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "milestoneTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "title", "status", "projects"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^[A-Z]{3}-\\d+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["backlog", "next", "needs_client", "in_review", "done"]
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project"
          },
          "minItems": 1
        }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "description",
        "projects",
        "status",
        "progress",
        "completedTasks",
        "totalTasks",
        "tasks"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project"
          },
          "minItems": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "blocked", "completed"]
        },
        "progress": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "completedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "totalTasks": {
          "type": "integer",
          "minimum": 0
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/milestoneTask"
          }
        }
      }
    },
    "app": {
      "$ref": "#/$defs/project"
    }
  }
}
